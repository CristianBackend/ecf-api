          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Tiene status', () => {",
                  "  const data = pm.response.json().data;",
                  "  pm.expect(data).to.have.property('status');",
                  "  console.log('Estado factura:', data.status);",
                  "});"
                ]
              }
            }
          ]
