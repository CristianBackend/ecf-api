      "description": "Suscripciones para notificaciones de eventos en tiempo real",
      "item": [
        {
          "name": "Crear Webhook",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/webhooks", "host": ["{{base_url}}"], "path": ["webhooks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"url\": \"https://mi-sistema.com/webhooks/ecf\",\n  \"events\": [\"invoice.accepted\", \"invoice.rejected\", \"invoice.contingency\"]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Crea un webhook. El `secret` en la respuesta solo se muestra una vez — úsalo para verificar HMAC."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json().data;",
                  "if (data && data.id) {",
                  "  pm.collectionVariables.set('webhook_id', data.id);",
                  "  console.log('Webhook secret (guardar):', data.secret);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Listar Webhooks",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/webhooks", "host": ["{{base_url}}"], "path": ["webhooks"] }
          }
        },
        {
          "name": "Ver Webhook con Historial",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/webhooks/{{webhook_id}}", "host": ["{{base_url}}"], "path": ["webhooks", "{{webhook_id}}"] }
          }
        },
        {
          "name": "Actualizar Webhook",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/webhooks/{{webhook_id}}", "host": ["{{base_url}}"], "path": ["webhooks", "{{webhook_id}}"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"events\": [\"invoice.accepted\", \"invoice.rejected\"],\n  \"isActive\": true\n}",
              "options": { "raw": { "language": "json" } }
            }
          }
        },
        {
          "name": "Eliminar Webhook",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{base_url}}/webhooks/{{webhook_id}}", "host": ["{{base_url}}"], "path": ["webhooks", "{{webhook_id}}"] }
          }
        }
