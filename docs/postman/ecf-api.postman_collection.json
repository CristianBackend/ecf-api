          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201', () => pm.response.to.have.status(201));",
                  "const data = pm.response.json().data;",
                  "if (data && data.token) pm.collectionVariables.set('download_token', data.token);"
                ]
              }
            }
          ]
        },
