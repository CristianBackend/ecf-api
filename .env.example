# =============================================================================
# ECF-API — Environment Configuration
# =============================================================================
# Copy to .env and fill in real values. The app validates this file at boot
# (src/config/env.validation.ts); startup fails fast when any REQUIRED
# variable is missing, empty, or malformed.
#
# Secrets such as JWT_SECRET and CERT_ENCRYPTION_KEY must be generated with
# a CSPRNG:
#
#   openssl rand -hex 32           # 64 hex chars = 32 bytes
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# =============================================================================

# ------------------------ App ------------------------------------------------
NODE_ENV=development                # development | test | production
PORT=3000
API_PREFIX=api/v1
# CORS — allowed origins (comma-separated, no spaces around commas)
# Examples:
#   dev/test:    CORS_ORIGIN=*
#   single prod: CORS_ORIGIN=https://node-a2.newplain.com
#   multi prod:  CORS_ORIGIN=https://node-a2.newplain.com,http://localhost:3000
# NEVER put "*" in production — Joi validation will reject it at boot.
CORS_ORIGIN=*

# ------------------------ Database -------------------------------------------
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecf_api?schema=public
DB_PASSWORD=postgres                # used by docker-compose.yml
DB_PORT=5432                        # used by docker-compose.yml

# ------------------------ Redis ----------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ------------------------ Auth / JWT -----------------------------------------
# REQUIRED. Minimum 32 characters. DO NOT share this value with
# CERT_ENCRYPTION_KEY — they are rotated independently.
JWT_SECRET=
JWT_EXPIRATION=24h                  # zeit/ms duration string
API_KEY_PREFIX=frd

# ------------------------ Certificates ---------------------------------------
# REQUIRED in every environment. Exactly 64 hex characters (32 bytes). Used
# to AES-256-GCM encrypt .p12 containers, passphrases, and webhook HMAC
# secrets at rest. See README.md -> "Rotación de claves de cifrado".
CERT_ENCRYPTION_KEY=

# ------------------------ DGII -----------------------------------------------
DGII_ENVIRONMENT=DEV                # DEV | CERT | PROD
DGII_STATUS_API_KEY=                # for https://statusecf.dgii.gov.do (Apikey header)
DGII_HTTP_TIMEOUT_MS=30000

# ------------------------ Rate limiting --------------------------------------
THROTTLE_TTL=60000                  # window in ms
THROTTLE_LIMIT=60                   # requests per window per IP

# ------------------------ AWS (optional, for KMS/S3 migration) ---------------
AWS_REGION=us-east-1
AWS_KMS_KEY_ID=
AWS_S3_BUCKET=

# ------------------------ Logging --------------------------------------------
LOG_LEVEL=debug                     # trace | debug | info | warn | error
